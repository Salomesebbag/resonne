{
  "version": 2,
  "name": "resonne",
  "builds": [{ "src": "**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/(.*)","dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/assets/videos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
